# ─── Meta WhatsApp Cloud API ───────────────────────────────────────────────
# From your Meta App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_or_temporary_access_token
PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v21.0

# Webhook verification (you choose this string; enter the same value in the
# Meta App dashboard when configuring the webhook callback URL)
VERIFY_TOKEN=choose_a_random_verify_token

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000

# Default language served before a user picks one: en | am | om
DEFAULT_LANG=en

# ─── Manager dashboard ─────────────────────────────────────────────────────
# Password for the analytics dashboard at /admin (HTTP Basic — any username,
# this as the password). Leave unset to keep the dashboard disabled.
ADMIN_TOKEN=choose_a_strong_dashboard_password

# ─── Public landing page ───────────────────────────────────────────────────
# WhatsApp business number the landing-page QR code / "Chat" button deep-link
# to (international format; +, spaces and dashes are ignored). Unset = the page
# shows a "coming soon" placeholder instead of the QR.
PUBLIC_WA_NUMBER=+2519XXXXXXXX
# Optional pre-filled first message when a visitor taps through (default "Hi").
PUBLIC_WA_MESSAGE=Hi
