{
  "name": "zega-digital-whatsapp-bot",
  "version": "1.0.0",
  "description": "Zega Digital ዜጋ ዲጂታል — a digital-literacy WhatsApp bot for Ethiopia (My Digital World content), built on the Meta WhatsApp Cloud API.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "cli": "node scripts/cli.js",
    "tester": "node scripts/web-tester.js",
    "scheduler": "node scripts/scheduler.js",
    "metrics": "node scripts/metrics.js",
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=85 --test-coverage-branches=70",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "digital-literacy",
    "ethiopia",
    "meta-cloud-api"
  ],
  "author": "Zega Digital",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.22.0",
    "sharp": "^0.35.3"
  }
}
